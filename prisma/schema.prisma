generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ---------- Enums ----------

enum Color {
  RED
  GREEN
  BLUE
  PURPLE
  BLACK
  YELLOW
}

enum MatchResult {
  WIN
  LOSS
}

enum TournamentType {
  LOCAL
  REGIONAL
  NATIONAL
  ONLINE
  OTHER
}

// ---------- Référence ----------

model Leader {
  id        String   @id @default(uuid())
  code      String   @unique
  name      String
  colors    Color[]
  imageUrl  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  decks           Deck[]
  opponentMatches Match[]

  @@index([name])
}

// ---------- Domaine ----------

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  username  String
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  decks         Deck[]
  tournaments   Tournament[]
  refreshTokens RefreshToken[]
}

model Deck {
  id         String   @id @default(uuid())
  name       String
  notes      String?
  decklist   Json?
  isArchived Boolean  @default(false)
  isFavorite Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  leaderId String
  leader   Leader @relation(fields: [leaderId], references: [id])

  matches Match[]

  @@index([userId])
  @@index([leaderId])
}

model Tournament {
  id        String         @id @default(uuid())
  name      String
  date      DateTime
  type      TournamentType
  rounds    Int?
  notes     String?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  matches Match[]

  @@index([userId])
}

model Match {
  id           String      @id @default(uuid())
  opponentName String?
  result       MatchResult
  diceRollWon  Boolean?
  wentFirst    Boolean?
  score        String?
  notes        String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  playerDeckName     String?
  playerLeaderCode   String?
  playerLeaderName   String?
  opponentLeaderCode String?
  opponentLeaderName String?

  tournamentId String
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  deckId String?
  deck   Deck?   @relation(fields: [deckId], references: [id], onDelete: SetNull)

  opponentLeaderId String?
  opponentLeader   Leader? @relation(fields: [opponentLeaderId], references: [id], onDelete: SetNull)

  @@index([tournamentId])
  @@index([deckId])
  @@index([opponentLeaderId])
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}